<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>HTML Snippet Generator</title>
  <style>
    :root{
      --bg:#0b1020;
      --panel:rgba(255,255,255,.08);
      --panel2:rgba(255,255,255,.06);
      --text:#eef2ff;
      --muted:rgba(238,242,255,.72);
      --border:rgba(255,255,255,.14);
      --shadow: 0 18px 50px rgba(0,0,0,.35);
      --radius: 18px;
      --accent:#7c3aed;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      color:var(--text);
      background:
        radial-gradient(900px 600px at 10% -10%, rgba(124,58,237,.40), transparent 55%),
        radial-gradient(900px 600px at 90% 0%, rgba(59,130,246,.25), transparent 55%),
        var(--bg);
      padding:32px 16px;
    }
    .wrap{max-width:1120px;margin:0 auto;}
    .top{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:wrap;}
    h1{margin:0;font-size:26px;}
    .muted{color:var(--muted);font-size:13.5px;line-height:1.4;margin-top:6px;}
    .btn{
      display:inline-flex; align-items:center; gap:8px;
      padding:10px 12px;border-radius:14px;
      border:1px solid var(--border);
      text-decoration:none;color:var(--text);
      background: linear-gradient(180deg, var(--panel), var(--panel2));
      box-shadow: 0 10px 25px rgba(0,0,0,.18);
    }
    .grid{display:grid;grid-template-columns: 1fr;gap:14px;margin-top:18px;}
    @media(min-width:980px){ .grid{grid-template-columns: 1.1fr .9fr;} }
    .card{
      background: linear-gradient(180deg, var(--panel), var(--panel2));
      border:1px solid var(--border);
      border-radius: var(--radius);
      padding:18px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
    }
    textarea{
      width:100%;
      min-height:360px;
      border-radius:16px;
      border:1px solid var(--border);
      padding:14px;
      background: rgba(0,0,0,.18);
      color: var(--text);
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 12.5px;
      line-height: 1.45;
      outline:none;
      resize: vertical;
    }
    textarea:focus{border-color: rgba(124,58,237,.7); box-shadow: 0 0 0 4px rgba(124,58,237,.20);}
    .preview{
      background: rgba(0,0,0,.14);
      border:1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
    }
    .kce-card{border:1px solid rgba(255,255,255,.16);b
